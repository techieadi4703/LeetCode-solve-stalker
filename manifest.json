{
  "manifest_version": 3,
  "name": "LeetCode Solve Tracker",
  "version": "1.4",
  "description": "Track multiple users and see who solved the current LeetCode problem.",
  "permissions": ["activeTab", "scripting", "storage"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "content_scripts": [
    {
      "matches": ["*://leetcode.com/problems/*"],
      "js": ["content.js"]
    }
  ]
}
